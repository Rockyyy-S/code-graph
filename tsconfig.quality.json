{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["node", "vitest"]
  },
  "include": [
    "scripts/**/*.mjs",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vitest.contract.config.ts"
  ],
  "exclude": ["node_modules", "tests/fixtures/**"]
}
